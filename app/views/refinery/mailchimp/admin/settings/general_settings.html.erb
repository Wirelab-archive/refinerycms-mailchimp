<%= form_tag refinery.general_settings_mailchimp_admin_settings_path do %>

  <div class='field'>
    <span class='label_with_help'>
      <%= label_tag :recipients, t('.value') %>
    </span>
    <%= text_field_tag :recipients, @recipients, :class => "larger widest" %>
  </div>

  <p>
    <%= t('.hint') %>
  </p>
  <p>
    <%= t('.example') %>
  </p>

  <%= render "/refinery/admin/form_actions",
             :f => nil,
             :continue_editing => false,
             :cancel_url => "refinery.mailchimp_admin_campaigns_url",
             :hide_delete => true %>
<% end %>
